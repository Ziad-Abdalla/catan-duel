<!doctype html>
<html>
<head>
<meta http-equiv="x-ua-compatible" content="ie=edge" />
<meta http-equiv="content-type" content="text/html; charset=utf-8" />
<title>Catan Duel</title>
<hta:application id="app" applicationname="Catan Duel" border="thin" innerborder="no"
   scroll="no" maximizebutton="no" sysmenu="yes" caption="yes" contextmenu="no" selection="no" />
<style>
  html,body { margin:0; height:100%; font:14px/1.5 "Segoe UI",Arial,sans-serif;
              background:#0c1a1c; color:#f3ecd9; -ms-user-select:none; overflow:hidden; }
  .wrap { padding:22px 26px; }
  h1 { font-family:Georgia,serif; color:#f3d79a; margin:0; font-size:26px; }
  .sub { color:#9bb0ad; margin:3px 0 20px; font-size:12.5px; }

  /* status panel */
  .status { background:#15211f; border:1px solid #2c4446; border-radius:12px; padding:6px 16px; margin-bottom:20px; }
  .row { display:flex; align-items:center; padding:11px 0; border-bottom:1px solid #213230; }
  .row:last-child { border-bottom:0; }
  .row .lab { color:#9bb0ad; font-size:12.5px; width:120px; }
  .row .val { flex:1; }
  .dot { display:inline-block; width:11px; height:11px; border-radius:50%; background:#5a6a68; margin-right:9px; vertical-align:-1px; }
  .up { background:#7fd99a; box-shadow:0 0 8px rgba(127,217,154,.5); }
  .down { background:#c75c54; } .warn { background:#e6b34a; box-shadow:0 0 8px rgba(230,179,74,.45); }
  .ip { font-family:Consolas,monospace; color:#7fd0e0; }
  .refresh { margin-left:auto; font-size:11.5px; color:#7fd0e0; cursor:pointer; }
  .refresh:hover { text-decoration:underline; }

  /* buttons */
  .primary { display:flex; gap:12px; margin-bottom:12px; }
  .primary button { flex:1; }
  button { font:600 14px "Segoe UI",Arial; color:#13100a; background:#e0b341; border:0; border-radius:10px;
           padding:14px 16px; cursor:pointer; }
  button:hover { background:#efc457; }
  button.big { font-size:15px; padding:16px; }
  .secondary { display:flex; gap:12px; margin-bottom:20px; }
  .secondary button { flex:1; background:#22343a; color:#f3ecd9; border:1px solid #34525a; font-weight:600; padding:11px; }
  .secondary button:hover { background:#2c424a; }

  .card { background:#15211f; border:1px solid #2c4446; border-radius:12px; padding:14px 16px; margin-bottom:14px; }
  .card h2 { margin:0 0 8px; font-size:12.5px; color:#f3d79a; letter-spacing:.02em; }
  .linkrow { display:flex; align-items:center; gap:10px; }
  .lnk { font-family:Consolas,monospace; color:#7fd0e0; font-size:13px; flex:1; word-break:break-all; }
  .mini { font:600 12px "Segoe UI",Arial; color:#f3ecd9; background:#22343a; border:1px solid #34525a;
          border-radius:8px; padding:8px 12px; cursor:pointer; white-space:nowrap; }
  .mini:hover { background:#2c424a; }
  input { font:13px Consolas,monospace; background:#0a1314; color:#f3e6c6; border:1px solid #34525a;
          border-radius:8px; padding:9px 11px; flex:1; }
  a { color:#e0b341; } .note { color:#80938f; font-size:11.5px; line-height:1.6; }
</style>
</head>
<body>
<div class="wrap">
  <h1>Catan Duel</h1>
  <div class="sub">Your control panel. The buttons set up, start and host the game for you.</div>

  <div class="status">
    <div class="row"><span class="lab">Game</span>
      <span class="val"><span id="dGame" class="dot"></span><span id="tGame">checking...</span></span>
      <span class="refresh" onclick="refresh()">↻ refresh</span></div>
    <div class="row"><span class="lab">Firewall</span>
      <span class="val"><span id="dFw" class="dot"></span><span id="tFw">...</span></span></div>
    <div class="row"><span class="lab">Your Radmin IP</span>
      <span class="val ip" id="tIp">...</span></div>
  </div>

  <div class="primary">
    <button class="big" onclick="play()">▶  Play on this PC</button>
    <button class="big" onclick="host()">Host online</button>
  </div>
  <div class="secondary">
    <button onclick="stop()">⏹  Stop</button>
    <button onclick="update()">⬆  Update</button>
  </div>

  <div class="card">
    <h2>SEND YOUR FRIEND THE LINK</h2>
    <div class="linkrow">
      <span id="friend" class="lnk">start a game / connect Radmin to see your link</span>
      <button class="mini" onclick="copyFriend()">Copy</button>
    </div>
  </div>

  <div class="card">
    <h2>JOINING A FRIEND'S GAME?</h2>
    <div class="linkrow">
      <input id="join" placeholder="paste their link or 26.x.x.x" />
      <button class="mini" onclick="joinGame()">Open</button>
    </div>
    <div class="note" style="margin-top:8px">You just need <a href="https://www.radmin-vpn.com/">Radmin VPN</a> + their network - nothing to set up on your side.</div>
  </div>

  <div class="note">First time online: both install <a href="https://www.radmin-vpn.com/">Radmin VPN</a> (free) and join one network. "Host online" opens the firewall to Radmin peers only and closes it safely after.</div>
</div>

<script language="JScript">
var sh = new ActiveXObject("WScript.Shell");
var fso = new ActiveXObject("Scripting.FileSystemObject");
var radminIp = "";
var fwOpenNow = false;

function psFile(args, show) {
  try { sh.Run('powershell -NoProfile -ExecutionPolicy Bypass -File "' + here() + '\\RADMIN.ps1" ' + args, show ? 1 : 0, false); }
  catch (e) { alert("Could not run the online panel.\n" + e.message); }
}

function here() {
  var p = decodeURIComponent(location.pathname).replace(/^\//, "").replace(/\//g, "\\");
  return p.replace(/\\[^\\]*$/, ""); // folder this .hta sits in
}
function runBat(name, show) {
  try { sh.Run('"' + here() + '\\' + name + '"', show ? 1 : 0, false); }
  catch (e) { alert("Could not run " + name + ".\n" + e.message); }
}

function play()   { runBat("PLAY.bat", true); }
function host()   { psFile("-Open", true);  setTimeout(refresh, 6000); }   // host now: env+servers+firewall (click YES on UAC)
function stop()   {
  if (fwOpenNow) { psFile("-Close", true); }   // hosting: close firewall + bridge + stop servers (click YES on UAC)
  else { runBat("STOP.bat", false); }          // local only: just stop the game
  setTimeout(refresh, 2500);
}
function update() { runBat("UPDATE.bat", true); }

function joinGame() {
  var v = document.getElementById("join").value.replace(/^\s+|\s+$/g, "");
  if (!v) { alert("Paste your friend's link or Radmin IP first."); return; }
  if (v.indexOf("http") !== 0) v = "http://" + v.replace(/:5173$/, "") + ":5173";
  try { window.clipboardData.setData("Text", v); } catch (e) {}
  sh.Run('cmd /c start "" "' + v + '"', 0, false);
}
function copyFriend() {
  if (!radminIp) { alert("No Radmin IP yet - connect Radmin VPN, then ↻ refresh."); return; }
  var link = "http://" + radminIp + ":5173";
  try { window.clipboardData.setData("Text", link); alert("Copied:  " + link); } catch (e) { alert(link); }
}

function refresh() {
  try {
    var tmp = sh.ExpandEnvironmentStrings("%TEMP%") + "\\catan_status.txt";
    var ps = "$g=try{if((Invoke-WebRequest 'http://localhost:5173' -TimeoutSec 1 -UseBasicParsing).StatusCode -eq 200){'UP'}else{'DOWN'}}catch{'DOWN'};"
           + "$f=(Get-NetFirewallRule -DisplayName 'Catan Duel*' -EA SilentlyContinue|Measure-Object).Count;"
           + "$ip=(Get-NetIPAddress -AddressFamily IPv4|?{$_.IPAddress -like '26.*'}|Select-Object -First 1).IPAddress;"
           + "Set-Content -Encoding ascii -Path '" + tmp + "' -Value ($g+'|'+$f+'|'+$ip)";
    sh.Run('powershell -NoProfile -WindowStyle Hidden -Command "' + ps + '"', 0, true);
    var s = "DOWN|0|";
    if (fso.FileExists(tmp)) { var fh = fso.OpenTextFile(tmp, 1); s = fh.ReadAll(); fh.Close(); }
    var p = s.replace(/\s+$/, "").split("|");
    var gameUp = (p[0] === "UP"), fwOpen = (parseInt(p[1], 10) > 0); radminIp = p[2] || "";
    fwOpenNow = fwOpen;
    document.getElementById("dGame").className = "dot " + (gameUp ? "up" : "down");
    document.getElementById("tGame").innerHTML = gameUp ? "running - <a href='http://localhost:5173'>open the game</a>" : "not running - press Play";
    document.getElementById("dFw").className = "dot " + (fwOpen ? "warn" : "up");
    document.getElementById("tFw").innerHTML = fwOpen ? "open (Radmin peers only)" : "closed - safe, not exposed";
    document.getElementById("tIp").innerHTML = radminIp ? radminIp : "Radmin not connected";
    document.getElementById("friend").innerHTML = radminIp ? ("http://" + radminIp + ":5173") : "start a game / connect Radmin to see your link";
  } catch (e) { /* ignore one failed poll */ }
}

window.resizeTo(600, 660);
refresh();
window.setInterval(refresh, 8000);
</script>
</body>
</html>
